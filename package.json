{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "codegen": "php artisan wayfinder:generate --with-form --no-interaction && php artisan ziggy:generate --no-interaction",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint --ext .js,.jsx,.ts,.tsx,.vue ./resources",
        "lint:fix": "eslint --fix --ext .js,.jsx,.ts,.tsx,.vue ./resources",
        "typecheck": "bun run codegen && vue-tsc --noEmit",
        "typecheck:client": "bun run codegen && tsc --noEmit -p tsconfig.client.json"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.2.0",
        "@eslint/js": "^9.19.0",
        "@iconify-json/heroicons": "^1.2.3",
        "@iconify-json/lucide": "^1.2.88",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@tailwindcss/vite": "^4.1.11",
        "@types/node": "^22.13.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^7.0.7",
        "vue-tsc": "^3.2.4"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.3.7",
        "@nuxt/ui": "^4.5.1",
        "@vueuse/core": "^12.8.2",
        "clsx": "^2.1.1",
        "laravel-vite-plugin": "^2.0.0",
        "lucide-vue-next": "^0.468.0",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.1.1",
        "vue": "^3.5.13",
        "ziggy-js": "^2.6.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@rollup/rollup-win32-x64-msvc": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1",
        "lightningcss-win32-x64-msvc": "^1.29.1"
    }
}
